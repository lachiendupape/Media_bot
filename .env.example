# Media Bot Environment Variables

# --- Service URLs (use direct LAN IPs for best performance) ---

# Tautulli
TAUTULLI_URL=http://YOUR_SERVER_IP:8181
TAUTULLI_API_KEY=your_api_key
TAUTULLI_WELCOME_ENABLED=false
TAUTULLI_WELCOME_DAYS=7
TAUTULLI_WELCOME_TOP_SHOWS=3
TAUTULLI_WELCOME_CACHE_SECONDS=900
TAUTULLI_PHASE2_ENABLED=false
TAUTULLI_PHASE2_MIN_COMPLETION_RATIO=0.9
TAUTULLI_PHASE2_MAX_SUGGESTIONS=1

# Radarr
RADARR_URL=http://YOUR_SERVER_IP:7878/radarr
RADARR_API_KEY=your_api_key

# Sonarr
SONARR_URL=http://YOUR_SERVER_IP:8989/sonarr
SONARR_API_KEY=your_api_key

# Lidarr
LIDARR_URL=http://YOUR_SERVER_IP:8686/lidarr
LIDARR_API_KEY=your_api_key

# --- Authentication ---

# API key for programmatic access (X-Api-Key header)
BOT_API_KEY=your_api_key_here

# Flask session secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
FLASK_SECRET_KEY=change_me_to_a_random_string

# Set to 'production' when behind HTTPS proxy (enables Secure cookie flag)
# FLASK_ENV=production

# --- Plex OAuth ---
PLEX_SERVER_URL=http://YOUR_SERVER_IP:32400
PLEX_TOKEN=
PLEX_MACHINE_ID=your_plex_server_machine_id
PLEX_CLIENT_ID=your_random_uuid
PLEX_APP_NAME=Media Bot

# Optional but recommended: used for TV actor reverse lookups because Sonarr v4
# does not expose a working series credit endpoint.

# Plex username of the server owner — only this account may delete media via the bot
OWNER_PLEX_USERNAME=your_plex_username

# --- Media Add Defaults ---
# Global tags applied to all bot-created requests.
MEDIA_BOT_TAG=media-bot
KIDS_CONTENT_TAG=kids

# Optional per-request requester tagging.
# When enabled, the bot adds a sanitized username tag alongside MEDIA_BOT_TAG.
ENABLE_REQUESTER_TAGGING=false
# Optional prefix prepended to requester tags (for example: req-).
REQUESTER_TAG_PREFIX=

# Radarr defaults
RADARR_MOVIE_ROOT=/movies
RADARR_KIDS_MOVIE_ROOT=/kidsmovies
RADARR_DEFAULT_QUALITY_PROFILE=HD-1080p
RADARR_MINIMUM_AVAILABILITY=released

# Sonarr defaults
SONARR_TV_ROOT=/tv
SONARR_KIDS_TV_ROOT=/kidstv
SONARR_DEFAULT_QUALITY_PROFILE=HD - 720p/1080p
SONARR_SERIES_TYPE=standard

# --- Kids/Adults Auto-Classification ---
# When true, the bot attempts to classify media as kids/adults using metadata.
# If classification is ambiguous, it asks the user to confirm.
AUTO_CLASSIFY_KIDS_ENABLED=true

# Optional OMDb API key for improved kids/adults classification (especially TV).
# Leave blank to use local metadata + user confirmation only.
OMDB_API_KEY=
OMDB_TIMEOUT_SECONDS=5

# --- Download Quotas ---
# Set QUOTA_ENABLED=true to enforce daily per-user download limits.
# Limits reset at UTC midnight.  A value of 0 means unlimited.
# QUOTA_ENABLED=true
# DAILY_MOVIE_QUOTA=3
# DAILY_TV_SERIES_QUOTA=1
# Legacy alias for DAILY_TV_SERIES_QUOTA — still accepted for backwards compatibility.
# DAILY_TV_SEASON_QUOTA=1

# --- Watch-Based Auto-Cleanup ---
# Set CLEANUP_ENABLED=true to activate the cleanup service container.
#
# Policy:
#   - Content is checked every CLEANUP_CHECK_INTERVAL_DAYS days.
#   - If only the requester has watched it → deleted after the first interval.
#   - Hard delete after CLEANUP_MAX_AGE_DAYS regardless of who watched.
#   - Users see a backlog warning when requesting new content if they have
#     items older than CLEANUP_BACKLOG_WARN_DAYS that they haven't watched.
#
# CLEANUP_ENABLED=false
# CLEANUP_CHECK_INTERVAL_DAYS=7
# CLEANUP_MAX_AGE_DAYS=28
# CLEANUP_SCHEDULE_HOUR=3
# CLEANUP_BACKLOG_WARN_DAYS=3
# CLEANUP_MIN_WATCHED_EPISODES=1

# --- Data Directory ---
# Optional: override the directory used for SQLite databases and bug reports.
# Docker compose files set this automatically (/app/data or /app/data-dev).
# Only set this when running outside Docker and you want a custom data path.
# DATA_DIR=/path/to/data

# --- Ollama ---
# Override these when running in Docker (compose sets OLLAMA_BASE_URL automatically)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:14b

# Optional dev-only model override used by docker-compose.dev.yml
DEV_OLLAMA_MODEL=qwen2.5:7b

# Optional prod-only model override used by docker-compose.prod.yml
PROD_OLLAMA_MODEL=qwen2.5:14b

# --- Release / GitOps ---
# Used by docker-compose.prod.yml to pin the deployed image version.
# Examples: v1.3.0, 1.3.0, latest
MEDIA_BOT_VERSION=latest

# --- Observability / Error Reporting ---
# Application version label shown in the UI and attached to bug reports.
APP_VERSION=latest

# Logging verbosity (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Service name used for traces/observability exporters.
OBSERVABILITY_SERVICE_NAME=media-bot

# Optional Sentry DSN for backend error reporting.
SENTRY_DSN=

# Optional OpenTelemetry OTLP/HTTP traces endpoint.
# Example: http://grafana-agent:4318/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional GitHub issue creation from in-app bug reports.
# Repo format: owner/repo
GITHUB_ISSUES_REPO=
GITHUB_ISSUES_TOKEN=
# Keep disabled by default to avoid sending prompt/response text to GitHub.
# Set true only if you explicitly want issue bodies to include last prompt/response context.
GITHUB_ISSUES_INCLUDE_CHAT_CONTEXT=false

# Comma-separated labels to add to all bug report issues (in addition to auto-generated labels).
# Auto-generated labels include: bug, enhancement, search, chat, ui, performance, security
GITHUB_ISSUE_LABELS=bug,reported-from-app

# --- Webhooks ---
# Optional shared secret for Radarr/Sonarr webhook endpoints.
# Set in Radarr/Sonarr under Settings > Connect > Webhook as:
#   Authorization: Bearer <your_secret>
# Required when FLASK_ENV=production.
# WEBHOOK_SECRET=your_webhook_secret_here

# --- Conversation Memory (Phase 1 Rollout) ---
# Enable persistent multi-turn conversation history per user/session.
# When disabled, chat retains only task-specific state (pending adds, follow-ups).
# CONVERSATION_MEMORY_ENABLED=true

# Maximum number of conversation turns (user + assistant pairs) to retain.
# When exceeded, the oldest turns are pruned.
# CONVERSATION_MEMORY_MAX_TURNS=20

# Time-to-live for conversation turns in hours. Set to 0 to disable TTL expiration.
# After this duration, turns are automatically deleted regardless of count.
# CONVERSATION_MEMORY_TTL_HOURS=24

# Run TTL cleanup on every Nth request (0 to disable opportunistic cleanup).
# Higher values reduce DB scan frequency; lower values keep DB smaller.
# CONVERSATION_MEMORY_CLEANUP_INTERVAL=100

# Purge browser-session conversation history on logout.
# API-key identities are not affected by /auth/logout.
# CONVERSATION_MEMORY_PURGE_ON_LOGOUT=true
