# Media Bot Environment Variables

# --- Service URLs (use direct LAN IPs for best performance) ---

# Tautulli
TAUTULLI_URL=http://YOUR_SERVER_IP:8181
TAUTULLI_API_KEY=your_api_key

# Radarr
RADARR_URL=http://YOUR_SERVER_IP:7878/radarr
RADARR_API_KEY=your_api_key

# Sonarr
SONARR_URL=http://YOUR_SERVER_IP:8989/sonarr
SONARR_API_KEY=your_api_key

# Lidarr
LIDARR_URL=http://YOUR_SERVER_IP:8686/lidarr
LIDARR_API_KEY=your_api_key

# NZBGet
NZBGET_URL=http://YOUR_SERVER_IP:6789
NZBGET_USER=
NZBGET_PASS=

# NZBHydra2
NZBHYDRA_URL=http://YOUR_SERVER_IP:5076
NZBHYDRA_API_KEY=your_api_key

# --- Authentication ---

# API key for programmatic access (X-Api-Key header)
BOT_API_KEY=your_api_key_here

# Flask session secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
FLASK_SECRET_KEY=change_me_to_a_random_string

# Set to 'production' when behind HTTPS proxy (enables Secure cookie flag)
# FLASK_ENV=production

# --- Plex OAuth ---
PLEX_SERVER_URL=http://YOUR_SERVER_IP:32400
PLEX_TOKEN=
PLEX_MACHINE_ID=your_plex_server_machine_id
PLEX_CLIENT_ID=your_random_uuid
PLEX_APP_NAME=Media Bot

# Optional but recommended: used for TV actor reverse lookups because Sonarr v4
# does not expose a working series credit endpoint.

# Plex username of the server owner — only this account may delete media via the bot
OWNER_PLEX_USERNAME=your_plex_username

# --- Download Quotas ---
# Set QUOTA_ENABLED=true to enforce daily per-user download limits.
# Limits reset at UTC midnight.  A value of 0 means unlimited.
# QUOTA_ENABLED=false
# DAILY_MOVIE_QUOTA=0
# DAILY_TV_SEASON_QUOTA=0

# --- Ollama ---
# Override these when running in Docker (compose sets OLLAMA_BASE_URL automatically)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:14b

# Optional dev-only model override used by docker-compose.dev.yml
DEV_OLLAMA_MODEL=qwen2.5:7b

# Optional prod-only model override used by docker-compose.prod.yml
PROD_OLLAMA_MODEL=qwen2.5:14b

# --- Release / GitOps ---
# Used by docker-compose.prod.yml to pin the deployed image version.
# Examples: v1.3.0, 1.3.0, latest
MEDIA_BOT_VERSION=latest

# --- Observability / Error Reporting ---
# Application version label shown in the UI and attached to bug reports.
APP_VERSION=latest

# Logging verbosity (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Service name used for traces/observability exporters.
OBSERVABILITY_SERVICE_NAME=media-bot

# Optional Sentry DSN for backend error reporting.
SENTRY_DSN=

# Optional OpenTelemetry OTLP/HTTP traces endpoint.
# Example: http://grafana-agent:4318/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional GitHub issue creation from in-app bug reports.
# Repo format: owner/repo
GITHUB_ISSUES_REPO=
GITHUB_ISSUES_TOKEN=

# Comma-separated labels to add to all bug report issues (in addition to auto-generated labels).
# Auto-generated labels include: bug, enhancement, search, chat, ui, performance, security
GITHUB_ISSUE_LABELS=reported-from-app
